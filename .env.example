# =============================================================================
# Cyron Ticket Assistant â€” backend & bot (copy to .env and fill in secrets)
# =============================================================================

# --- Discord application (Developer Portal â†’ OAuth2 + Bot) ---
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_OAUTH_SCOPE=identify guilds

# Bot token (Bot tab). Required for the discord.py service.
DISCORD_TOKEN=your_discord_bot_token

# OAuth callback URLs allowed when the dashboard calls GET /auth/discord.
# Comma-separated; must match Discord Developer Portal â†’ Redirects exactly.
DISCORD_OAUTH_ALLOWED_REDIRECT_URIS=https://cyron-assistant-frontend.vercel.app/auth/callback

# --- Public URLs (no trailing slash) ---
BACKEND_PUBLIC_URL=https://api.cyronticket.com
FRONTEND_PUBLIC_URL=https://cyron-assistant-frontend.vercel.app
FRONTEND_ALLOWED_ORIGINS=https://cyron-assistant-frontend.vercel.app

# --- Auth JWT (generate a long random string for production) ---
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXP_MINUTES=1440

# --- Shared secret: bot â†’ API (/relay, /internal/bot/*) ---
BOT_API_KEY=replace-with-a-long-random-secret

# --- Database (Docker Compose uses service name "postgres") ---
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_ticket_assistant

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- AI providers (at least one required for ticket replies) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
